<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>bundleid</key>
	<string>com.glincker.thesvg-alfred</string>
	<key>category</key>
	<string>Tools</string>
	<key>connections</key>
	<dict>
		<!-- Script Filter (UID: script-filter-01) connects to Run Script (UID: run-script-01) -->
		<key>script-filter-01</key>
		<array>
			<dict>
				<key>destinationuid</key>
				<string>run-script-01</string>
				<key>modifiers</key>
				<integer>0</integer>
				<key>modifiersubtext</key>
				<string></string>
				<key>vitoclose</key>
				<false/>
			</dict>
		</array>
	</dict>
	<key>createdby</key>
	<string>Glinr</string>
	<key>description</key>
	<string>Search and copy brand SVGs from theSVG (thesvg.org)</string>
	<key>disabled</key>
	<false/>
	<key>name</key>
	<string>theSVG</string>
	<key>objects</key>
	<array>
		<!-- Object 1: Script Filter (keyword trigger + search) -->
		<dict>
			<key>config</key>
			<dict>
				<key>alfredfiltersresults</key>
				<false/>
				<key>alfredfiltersresultsmatchmode</key>
				<integer>0</integer>
