				<integer>0</integer>
				<key>escaping</key>
				<integer>102</integer>
				<key>keyword</key>
				<string>tsvg</string>
				<key>queuedelaycustom</key>
				<integer>3</integer>
				<key>queuedelayimmediatelyinitially</key>
				<true/>
				<key>queuedelaymode</key>
				<integer>3</integer>
				<key>queuemode</key>
				<integer>1</integer>
				<key>runningsubtext</key>
				<string>Searching theSVG...</string>
				<key>script</key>
				<string>python3 "$alfred_workflow_dir/thesvg_search.py" "{query}"</string>
				<key>scriptargtype</key>
				<integer>1</integer>
				<key>scriptfile</key>
				<string></string>
				<key>subtext</key>
				<string>Search 6,030+ brand SVGs</string>
				<key>title</key>
				<string>theSVG - Search brand icons</string>
				<key>type</key>
				<integer>0</integer>
				<key>waitingsubtext</key>
				<string>Search 6,030+ brand SVGs</string>
				<key>withspace</key>
				<true/>
			</dict>
			<key>type</key>
			<string>alfred.workflow.input.scriptfilter</string>
			<key>uid</key>
			<string>script-filter-01</string>
			<key>version</key>
			<integer>3</integer>
		</dict>
		<!-- Object 2: Run Script (action handler) -->
		<dict>
			<key>config</key>
			<dict>
				<key>concurrently</key>
				<false/>
				<key>escaping</key>
				<integer>102</integer>
				<key>script</key>
				<string>python3 "$alfred_workflow_dir/thesvg_action.py" "{query}"</string>
